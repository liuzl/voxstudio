<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- launchd user agent for the FunASR transcription server on macOS. Replace %CHECKOUT%
     and %UV_BIN%; machine-specific values stay out of this public repo. -->
<plist version="1.0">
<dict>
  <key>Label</key><string>com.voxstudio.funasr-asr</string>
  <key>WorkingDirectory</key><string>%CHECKOUT%/engines/funasr</string>
  <key>ProgramArguments</key>
  <array>
    <string>%UV_BIN%</string>
    <string>run</string>
    <string>python</string>
    <string>server_funasr.py</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>FUNASR_PORT</key><string>18098</string>
    <key>FUNASR_HUB</key><string>hf</string>
    <key>FUNASR_MODEL</key><string>FunAudioLLM/SenseVoiceSmall</string>
    <key>FUNASR_DEVICE</key><string>mps</string>
  </dict>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>/tmp/funasr-asr.log</string>
  <key>StandardErrorPath</key><string>/tmp/funasr-asr.log</string>
</dict>
</plist>

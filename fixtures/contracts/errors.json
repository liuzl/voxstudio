  },
  {
    "name": "cpp error envelope",
    "status": 400,
    "body": {"error": {"code": "voice_not_found", "message": "Unknown voice id."}},
    "expected": {"code": "voice_not_found", "message": "Unknown voice id."}
  },
  {
    "name": "non-json gateway response",
